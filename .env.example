# =============================================================================
# NestJS Starter Kit — Environment Variables
# =============================================================================
#
# HOW TO USE THIS FILE
#   1. Copy this file to ".env" in the project root:  cp .env.example .env
#   2. Fill in real values for every variable marked "REQUIRED" below.
#   3. Review the OPTIONAL variables and override any whose defaults are
#      not appropriate for your environment.
#
# SECURITY
#   - This file (.env.example) contains NO real secrets — every value here is
#     a placeholder. It is safe to commit to version control.
#   - Your ".env" file WILL contain real secrets once filled in. It is
#     git-ignored by default — NEVER commit it, never paste its contents into
#     issues/PRs/chat, and never log its values.
#   - Use different secrets per environment (local/dev/staging/production).
#     Never reuse a production secret in a lower environment or vice versa.
#
# =============================================================================


# ==================== Server ====================

# Runtime environment mode. One of: development | production | test.
# Affects security headers (Helmet CSP/COEP only in production), CORS
# (origin forced to allow-all in development, regardless of ALLOWED_ORIGINS),
# request log format, whether Swagger UI/JSON is mounted (mounted only when
# NOT production), refresh-token cookie "secure" flag (production only), and
# the implicit default for DB_SSL (true in production, false otherwise).
# OPTIONAL — defaults to "development". Always set explicitly to "production" in prod.
NODE_ENV=development

# TCP port the HTTP server listens on. Also used to build the default APP_URL
# (http://localhost:<PORT>) when APP_URL is unset.
# OPTIONAL — defaults to 3000.
PORT=3000

# Network interface the HTTP server binds to. Use "0.0.0.0" so the app is
# reachable from outside its own container (Docker/Kubernetes). Use
# "127.0.0.1" to restrict to loopback-only (e.g. behind a local reverse proxy).
# OPTIONAL — defaults to "0.0.0.0".
HOST=0.0.0.0

# Maximum accepted request body size for JSON/urlencoded payloads, as an
# Express byte-string (e.g. "10mb", "512kb", "1gb").
# OPTIONAL — defaults to "10mb".
BODY_SIZE_LIMIT=10mb


# ==================== App Identity ====================

# Human-readable application name. Used as the Swagger document title, the
# Swagger page's browser tab title, and in outbound email copy (e.g.
# "Reset your <APP_NAME> password"). Free text.
# OPTIONAL — defaults to "Application API".
APP_NAME="Acme Billing API"

# Short application description shown in the generated Swagger docs.
# OPTIONAL — defaults to "API Documentation".
APP_DESCRIPTION="Internal billing and invoicing service"

# Application version string, must be valid SemVer 2.0.0 (e.g. "1.0.0",
# "2.4.1-beta.1"). Only affects the version shown in Swagger docs — it is
# intentionally decoupled from package.json and does NOT control the URI API
# version prefix (that is hardcoded to "1" in src/main.ts).
# OPTIONAL — defaults to "1.0.0".
APP_VERSION=1.0.0


# ==================== Database (PostgreSQL / Prisma) ====================

# PostgreSQL connection string used by Prisma (via pg.Pool + @prisma/adapter-pg),
# the seed script, and prisma.config.ts for migrations/CLI.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>?schema=public
# REQUIRED — no default.
DATABASE_URL="postgresql://app_user:CHANGE_ME_PASSWORD@localhost:5432/nestjs_starter_kit?schema=public"

# Maximum number of connections in the Postgres connection pool. Size
# proportionally to Postgres's max_connections divided by the number of
# app replicas you run.
# OPTIONAL — defaults to 10.
DB_POOL_MAX=10

# Milliseconds to wait when acquiring a new connection from the pool before
# giving up (connectionTimeoutMillis).
# OPTIONAL — defaults to 3000.
DB_CONN_TIMEOUT_MS=3000

# Milliseconds an idle pooled connection is kept open before being released
# (idleTimeoutMillis).
# OPTIONAL — defaults to 30000.
DB_IDLE_TIMEOUT_MS=30000

# Milliseconds a query waits to acquire a row/table lock before failing fast
# (Postgres `lock_timeout`). Kept shorter than DB_STATEMENT_TIMEOUT_MS so lock
# contention fails fast instead of occupying a connection for the full
# statement timeout.
# OPTIONAL — defaults to 5000.
DB_LOCK_TIMEOUT_MS=5000

# Milliseconds before Postgres cancels any single running statement
# (Postgres `statement_timeout`), preventing a runaway query from exhausting
# the connection pool.
# OPTIONAL — defaults to 30000.
DB_STATEMENT_TIMEOUT_MS=30000

# Force-enable/disable TLS on Postgres connections. Set to "true" or "false".
# OPTIONAL — if unset, defaults to true when NODE_ENV=production and false
# otherwise (e.g. local Docker Postgres without SSL). Leave unset for most
# setups; override to "false" only for dev/staging DBs that don't run SSL.
# DB_SSL=false


# ==================== JWT & Auth Tokens ====================

# Secret used to SIGN and VERIFY short-lived JWT access tokens (HS256).
# Must be a long, random string — at least 32 characters — and MUST be
# DIFFERENT from JWT_REFRESH_SECRET. Generate one with:
#   openssl rand -hex 32
# REQUIRED — no default. Rotating this invalidates all issued access tokens.
JWT_ACCESS_SECRET=changeme-generate-a-64-char-random-string-with-openssl

# Secret validated at startup alongside JWT_ACCESS_SECRET (min 32 chars) for
# a refresh-token JWT scheme. NOTE: refresh tokens in this app are currently
# opaque random tokens (hashed and stored in the database with rotation +
# reuse detection), not signed JWTs, so this value has no runtime effect
# beyond the startup check — but it is still required, must be set, and
# MUST be DIFFERENT from JWT_ACCESS_SECRET in case it is wired up later.
# Generate one with:
#   openssl rand -hex 32
# REQUIRED — no default.
JWT_REFRESH_SECRET=changeme-generate-a-different-64-char-random-string

# Lifetime of the access token. Format: <number><s|m|h|d> (e.g. "15m", "1h").
# OPTIONAL — defaults to "15m". Keep short since access tokens can't be revoked.
JWT_ACCESS_EXPIRES_IN=15m

# Lifetime of the refresh token (both the database record and the
# refresh_token cookie's maxAge). Format: <number><s|m|h|d> (e.g. "7d").
# OPTIONAL — defaults to "7d".
JWT_REFRESH_EXPIRES_IN=7d

# bcrypt cost factor (salt rounds) used when hashing passwords on register
# and password reset. Higher = slower to compute but more resistant to
# brute-force/offline cracking. Integer between 10 and 15.
# OPTIONAL — defaults to 12.
BCRYPT_ROUNDS=12


# ==================== Google OAuth ====================
# Entire block is OPTIONAL — "Sign in with Google" is an optional feature.
# If left unset, the app boots fine with a non-functional placeholder
# strategy; actually completing a Google login without real credentials
# will fail at that point rather than at startup. Can also be disabled at
# runtime independently via the Settings "enableGoogleLogin" flag.

# OAuth 2.0 Client ID from Google Cloud Console.
# OPTIONAL — no default; Google login is disabled/non-functional if unset.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# OAuth 2.0 Client Secret paired with GOOGLE_CLIENT_ID. Treat as sensitive.
# OPTIONAL — no default; Google login is disabled/non-functional if unset.
GOOGLE_CLIENT_SECRET=changeme-google-oauth-client-secret

# OAuth redirect URL that Google redirects back to after consent. Must
# exactly match an "Authorized redirect URI" configured for this client ID
# in Google Cloud Console, and must point at this app's own
# GET /api/v1/auth/google/callback route (this app returns JSON directly on
# success — it does not redirect on to a separate frontend).
# OPTIONAL — defaults to "http://localhost:3000/api/v1/auth/google/callback".
GOOGLE_CALLBACK_URL=https://api.example.com/api/v1/auth/google/callback


# ==================== Mail / SMTP ====================

# Outbound mail transport. One of: console | smtp.
# "console" (default) logs emails instead of sending them — no setup needed
# for local dev/CI. "smtp" sends real email via nodemailer and REQUIRES all
# SMTP_* variables below to be set (enforced at startup).
# OPTIONAL — defaults to "console".
MAIL_PROVIDER=console

# Default "From" address on all outbound email sent via the SMTP provider.
# OPTIONAL — defaults to "no-reply@example.com".
MAIL_FROM=no-reply@yourapp.com

# SMTP server hostname.
# OPTIONAL in general, but REQUIRED when MAIL_PROVIDER=smtp.
SMTP_HOST=smtp.example.com

# SMTP server port (e.g. 587 for STARTTLS, 465 for implicit TLS).
# OPTIONAL in general, but REQUIRED when MAIL_PROVIDER=smtp.
SMTP_PORT=587

# Whether to connect with TLS immediately (true, typically port 465) or
# connect plaintext and upgrade via STARTTLS (false, typically port 587/25).
# OPTIONAL — defaults to false. Not required even when MAIL_PROVIDER=smtp.
SMTP_SECURE=false

# SMTP auth username.
# OPTIONAL in general, but REQUIRED when MAIL_PROVIDER=smtp. Sensitive.
SMTP_USER=apikey

# SMTP auth password/secret.
# OPTIONAL in general, but REQUIRED when MAIL_PROVIDER=smtp. Sensitive —
# never logged, even on validation failure (only variable names are logged).
SMTP_PASSWORD=changeme-smtp-password-or-api-key


# ==================== Password Reset & Account Lockout ====================

# How many minutes a password-reset token (issued by POST /auth/forgot-password)
# remains valid before it's rejected. Integer between 5 and 1440 (24h).
# OPTIONAL — defaults to 30.
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=30

# How many consecutive failed login attempts are allowed before an account
# is locked out. Integer between 3 and 20.
# OPTIONAL — defaults to 5.
MAX_FAILED_ATTEMPTS=5

# How many minutes an account stays locked after exceeding MAX_FAILED_ATTEMPTS.
# During the lock window, login attempts get a generic "Invalid credentials"
# response (enumeration-safe). Cleared early by a successful login or password
# reset. Integer, minimum 1.
# OPTIONAL — defaults to 15.
LOCK_DURATION_MINUTES=15


# ==================== Security & Rate Limiting ====================

# Controls Express's "trust proxy" setting, which governs how req.ip (and
# therefore the Redis-backed rate limiter's per-client bucketing) is derived
# from the X-Forwarded-For header. Accepted values:
#   "false"            trust nothing (safe only when clients reach the app
#                       directly; NAT/proxy clients will share one IP bucket)
#   "true"              trust the nearest hop unconditionally (spoofable
#                       unless you're certain no untrusted client reaches the
#                       app directly — do not use this behind an untrusted
#                       edge)
#   a positive integer  trust exactly that many hops from the client
#   anything else       passed through as an Express subnet/keyword list
#                       (e.g. "loopback, 10.0.0.0/8")
# In production behind a load balancer/reverse proxy, set this to the exact
# hop count (commonly "1") rather than "true", to avoid IP spoofing.
# Rate-limit thresholds themselves (global: 100 req / 10 min, auth: 10 req /
# 15 min) are hardcoded and NOT configurable via env vars.
# OPTIONAL — defaults to "false".
TRUST_PROXY=1

# Comma-separated CORS allow-list. Each entry must be "*" or an http(s) URL.
# Only takes effect when NODE_ENV != "development" — in development CORS is
# always wide open regardless of this value. If unset outside development,
# CORS denies all cross-origin requests (fails closed, not wildcard-open).
# Set this explicitly for every non-development environment.
# OPTIONAL — no default (deny-all outside development).
ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# Redis connection URL backing the distributed (cross-replica) rate-limit
# counters and the settings cache. May embed credentials (redis://user:pass@host:port).
# Format: redis://[[user]:password@]host:port[/db]  (or rediss:// for TLS)
# REQUIRED — no default; there is no in-memory fallback.
REDIS_URL=redis://localhost:6379


# ==================== Frontend / URLs ====================

# Public base URL of THIS API (not a frontend URL). Used to build absolute
# links emailed to users (e.g. the password-reset link
# "${APP_URL}/reset-password?token=...") and other absolute links such as
# file-streaming URLs. Set this explicitly behind any reverse proxy/CDN in
# production — the fallback below is only correct for local development.
# OPTIONAL — defaults to "http://localhost:<PORT>".
APP_URL=https://app.example.com


# ==================== Storage ====================

# File storage backend. One of: local | cloud.
# "local" (default) writes uploads to disk. "cloud" uses S3-compatible
# storage and REQUIRES the STORAGE_AWS_* credentials below.
# OPTIONAL — defaults to "local".
STORAGE_PROVIDER=local

# Filesystem directory for uploads when STORAGE_PROVIDER=local. Relative or
# absolute path.
# OPTIONAL — defaults to "./storage".
LOCAL_STORAGE_DEST=./storage

# Maximum size (in megabytes) of a single uploaded file, enforced by Multer
# before the file is fully buffered into memory. Integer between 1 and 1024.
# OPTIONAL — defaults to 10.
STORAGE_MAX_FILE_SIZE_MB=10

# Comma-separated MIME type allow-list, enforced at the Multer layer and
# again in StorageService (defense-in-depth). Leaving this blank does NOT
# disable the check — it falls back to the safe default shown below, so
# uploads can't accidentally be opened to arbitrary file types (e.g. HTML,
# enabling stored XSS via the public file-stream route).
# OPTIONAL — defaults to "image/jpeg,image/png,image/webp,image/gif,application/pdf".
STORAGE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif,application/pdf

# AWS/S3 access key ID for the cloud storage provider.
# OPTIONAL in general, but REQUIRED when STORAGE_PROVIDER=cloud. Sensitive.
STORAGE_AWS_ACCESS_KEY_ID=changeme-aws-access-key-id

# AWS/S3 secret access key paired with STORAGE_AWS_ACCESS_KEY_ID.
# OPTIONAL in general, but REQUIRED when STORAGE_PROVIDER=cloud. Sensitive.
STORAGE_AWS_SECRET_ACCESS_KEY=changeme-aws-secret-access-key

# AWS region the S3 bucket lives in.
# OPTIONAL — defaults to "us-east-1".
STORAGE_AWS_REGION=us-east-1

# Name of the S3 bucket used for uploaded files.
# OPTIONAL in general, but REQUIRED when STORAGE_PROVIDER=cloud.
STORAGE_AWS_BUCKET_NAME=my-app-uploads

# Custom S3-compatible endpoint override, for non-AWS providers (e.g. MinIO,
# DigitalOcean Spaces) instead of AWS's default regional endpoint.
# OPTIONAL — leave unset to use AWS's default endpoint.
# STORAGE_AWS_ENDPOINT=http://localhost:9000
